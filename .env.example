# ============================================================
# AI Resume Intelligence Platform - Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# --- HuggingFace ---
HUGGINGFACE_API_KEY=hf_your_key_here
HF_LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- LLM Provider (huggingface | openai | gemini) ---
LLM_PROVIDER=huggingface

# --- OpenAI (optional fallback) ---
OPENAI_API_KEY=sk-your-key-here

# --- Google Gemini (optional fallback) ---
GOOGLE_API_KEY=your-gemini-key-here

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./resume_ai.db
# For PostgreSQL: postgresql+asyncpg://user:password@localhost:5432/resume_ai

# --- JWT Auth ---
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./vector_db/chroma_store
CHROMA_COLLECTION_NAME=resume_embeddings

# --- File Paths ---
UPLOAD_DIR=./uploads
REPORTS_DIR=./reports

# --- App Settings ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_PORT=8501
DEBUG=true

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000
